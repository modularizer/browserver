{
  "name": "browserver",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "A fully static in-browser IDE and dashboard for hosting client-side servers.",
  "packageManager": "npm@10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@browserver/studio",
    "dev:desktop": "npm run dev --workspace=@browserver/desktop",
    "desktop": "npm run start --workspace=@browserver/desktop",
    "build": "npm run build --workspaces --if-present",
    "build:studio": "npm run build --workspace=@browserver/studio",
    "build:viewer": "npm run build --workspace=@browserver/site-viewer",
    "build:playgoround": "npm run build --workspace=@browserver/api-playground",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "isomorphic-git": "^1.25.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
